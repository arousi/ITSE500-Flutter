# ─────────────────────────────────────────────────────────────
# Example environment file for flutter_app_itse500.
# Copy to `.env` and adjust. `.env` holds NON-SECRET config only.
#
# Real provider API keys (OpenAI, Gemini, OpenRouter, HuggingFace)
# are NEVER stored here. They are entered by the user in-app and
# persisted with flutter_secure_storage. On the backend they live
# as server-side deploy secrets, not in the client bundle.
# ─────────────────────────────────────────────────────────────

# Backend API base URLs (primary + dev fallbacks)
PRIMARY_API_BASE=https://your-backend-domain.example/api/v1/
SECONDARY_API_BASE=http://127.0.0.1:8000/api/v1/
TERTIARY_API_BASE=http://192.168.1.100:8000/api/v1/

# Local LM Studio endpoints
LMSTUDIO_BASE=http://localhost:1234/v1/
LMSTUDIO_EMULATOR_BASE=http://10.0.2.2:1234/v1/

# Provider API base URLs (public, non-secret)
GOOGLE_GEMINI_BASE=https://generativelanguage.googleapis.com/v1beta/
OPENAI_BASE=https://api.openai.com/v1/
OPENROUTER_BASE=https://openrouter.ai/api/v1/
