# Runtime configuration for NON-web builds (desktop/mobile) only.
# SECURITY: never put provider API keys here. This file is declared as a Flutter
# asset, so on the web build its bytes are part of the published bundle — any key
# placed here (even commented out) is publicly readable. Provider keys are
# per-user and come from the OAuth flow / the user entering them, stored in
# flutter_secure_storage — not from this file. On web, dotenv is initialized
# empty (see main.dart) and the defaults below live in code.

# Backend API base (non-secret). Web derives this in code; these are for desktop/mobile.
PRIMARY_API_BASE=https://itse500.swe.com.ly/api/v1/
SECONDARY_API_BASE=http://127.0.0.1:8000/api/v1/
TERTIARY_API_BASE=http://192.168.22.99:8000/api/v1/

LMSTUDIO_BASE=http://localhost:1234/v1/
LMSTUDIO_EMULATOR_BASE=http://10.0.2.2:1234/v1/

GOOGLE_GEMINI_BASE=https://generativelanguage.googleapis.com/v1beta/
OPENAI_BASE=https://api.openai.com/v1/
OPENROUTER_BASE=https://openrouter.ai/api/v1/
