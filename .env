# ─────────────────────────────────────────────────────────────
# Non-secret runtime configuration for flutter_app_itse500 (desktop/mobile).
# SECURITY: never put real API keys/secrets here — this file is a bundled Flutter
# asset tracked in git; on the web build its bytes are publicly readable. Provider
# keys are per-user, entered at runtime and stored via flutter_secure_storage, not
# from this file. On web, dotenv is initialized empty (see main.dart) and the app
# derives the backend base from same-origin; the defaults below are for desktop/mobile.
# See .env.example for the full list of supported variables.
# ─────────────────────────────────────────────────────────────

# Backend API base URLs (primary + dev fallbacks).
PRIMARY_API_BASE=https://itse500.swe.com.ly/api/v1/
SECONDARY_API_BASE=http://127.0.0.1:8000/api/v1/
TERTIARY_API_BASE=http://192.168.22.99:8000/api/v1/

# Local LM Studio endpoints
LMSTUDIO_BASE=http://localhost:1234/v1/
LMSTUDIO_EMULATOR_BASE=http://10.0.2.2:1234/v1/

# Provider API base URLs (public, non-secret)
GOOGLE_GEMINI_BASE=https://generativelanguage.googleapis.com/v1beta/
OPENAI_BASE=https://api.openai.com/v1/
OPENROUTER_BASE=https://openrouter.ai/api/v1/
